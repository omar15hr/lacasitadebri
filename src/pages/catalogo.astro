---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import CookieCard from "../components/CookieCard.astro";

const cookies = await getCollection("cookies");
---

<Layout title="Catálogo | La Casita de Bri">
  <section class="min-h-screen w-full bg-white relative pt-24 md:pt-22 pb-20">
    <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-14">
      <div class="mb-12 lg:mb-16">
        <h1
          class="climate text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[0.9] text-muted drop-shadow-sm mb-4 lg:mb-6"
        >
          Nuestro catálogo
        </h1>
        <p class="text-gray-primary text-lg sm:text-xl font-light max-w-2xl">
          Descubre todas nuestras galletas artesanales, horneadas diariamente
          con los mejores ingredientes.
          <strong class="font-bold text-gray-primary"
            >Cada pieza es única y feita con amor.</strong
          >
        </p>
      </div>

      <ul
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-12 list-none p-0"
      >
        {
          cookies.map((cookie) => (
            <li>
              <CookieCard cookie={cookie} />
            </li>
          ))
        }
      </ul>

      <div class="text-center">
        <a
          href="/arma-tu-caja"
          class="inline-flex items-center justify-center px-10 py-4 rounded-full bg-muted text-white text-xl font-bold tracking-wide transition-all duration-200 cursor-pointer hover:bg-primary hover:text-black hover:-translate-y-1"
        >
          Arma tu caja
        </a>
      </div>
    </div>
  </section>
</Layout>
