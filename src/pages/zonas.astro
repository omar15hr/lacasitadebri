---
import Layout from "../layouts/Layout.astro";

const zonas = [
  { nombre: "Providencia", envio: 2000, minima: 15000 },
  { nombre: "Las Condes", envio: 2000, minima: 15000 },
  { nombre: "Santiago Centro", envio: 2000, minima: 15000 },
  { nombre: "Ñuñoa", envio: 2500, minima: 18000 },
  { nombre: "La Reina", envio: 2500, minima: 18000 },
  { nombre: "Sanhattan", envio: 2500, minima: 18000 },
  { nombre: "Vitacura", envio: 3000, minima: 20000 },
  { nombre: "Peñalolén", envio: 3000, minima: 20000 },
  { nombre: "Macul", envio: 3000, minima: 20000 },
  { nombre: "Maipú", envio: 3500, minima: 25000 },
  { nombre: "La Florida", envio: 3500, minima: 25000 },
  { nombre: "San Bernardo", envio: 4000, minima: 30000 },
];

const formatearPrecio = (precio: number) => {
  return new Intl.NumberFormat("es-CL").format(precio);
};

const phone = "56949218394";
const message = encodeURIComponent(
  "Hola, me gustaría obtener más información sobre las zonas de reparto",
);
const waUrl = `https://wa.me/${phone}?text=${message}`;
---

<Layout title="Zonas de reparto | La Casita de Bri">
  <section
    class="min-h-screen w-full bg-[#fcfbf9] relative pt-24 md:pt-22 pb-20"
  >
    <div class="max-w-4xl mx-auto px-6 md:px-12 lg:px-24">
      <div class="mb-12 lg:mb-16 text-center">
        <h1
          class="climate text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[0.9] text-muted drop-shadow-sm mb-4 lg:mb-6"
        >
          Zonas de reparto
        </h1>
        <p
          class="text-gray-primary text-lg sm:text-xl font-light max-w-2xl mx-auto"
        >
          Realizamos entregas en diversas comunas de Santiago.
          <strong class="font-bold text-gray-primary"
            >Envío gratis en pedidos superiores al mínimo indicado.</strong
          >
        </p>
      </div>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5"
      >
        {
          zonas.map((zona) => (
            <div class="bg-white rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow">
              <h3 class="text-muted text-lg font-bold mb-3">{zona.nombre}</h3>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between items-center">
                  <span class="text-gray-primary font-light">Costo envío</span>
                  <span class="text-muted font-semibold">
                    ${formatearPrecio(zona.envio)}
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-primary font-light">Envío gratis</span>
                  <span class="text-muted font-semibold">
                    ${formatearPrecio(zona.minima)}
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-12 p-6 bg-primary/30 rounded-2xl text-center">
        <p class="text-muted text-base sm:text-lg font-medium mb-4">
          ¿No estás en alguna de estas zonas? ¡Contáctanos y buscaremos una
          solución!
        </p>
        <a
          href={waUrl}
          rel="noopener noreferrer"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-8 py-3 rounded-full bg-muted text-white font-semibold tracking-wide transition-all duration-200 cursor-pointer hover:bg-black hover:-translate-y-1"
        >
          Escríbenos por WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>
