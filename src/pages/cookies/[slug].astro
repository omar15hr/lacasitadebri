---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const cookies = await getCollection("cookies");
  return cookies.map((cookie) => ({
    params: { slug: cookie.id },
    props: { cookie },
  }));
}

const { cookie } = Astro.props;
---

<Layout title={`${cookie.data.name} | La Casita de Bri`}>
  <section
    class="min-h-[calc(100vh-[var(--header-height,80px)])] w-full bg-white relative flex items-center overflow-hidden pt-20 pb-40"
  >
    <div
      class="max-w-400 w-full mx-auto px-6 md:px-12 lg:px-24 flex flex-col md:flex-row items-center relative z-10 min-h-full"
    >
      <div
        class="w-full md:w-[60%] lg:w-[55%] relative h-[40vh] sm:h-[50vh] md:h-[80vh] flex items-center justify-center pointer-events-none mb-8 md:mb-0 z-0"
      >
        <Image
          src={cookie.data.image}
          alt={cookie.data.name}
          width={800}
          height={800}
          class="w-[120%] sm:w-[130%] md:w-[160%] lg:w-full max-w-none absolute left-[-10%] sm:left-[-15%] md:left-[-40%] lg:left-[-20%] top-1/2 -translate-y-1/2 object-contain"
          style="filter: drop-shadow(25px 25px 35px rgba(0,0,0,0.5));"
        />
      </div>

      <div
        class="w-full md:w-[40%] lg:w-[40%] z-10 flex flex-col justify-center text-left relative"
      >
        <h1
          class="w-full climate text-5xl sm:text-6xl md:text-7xl lg:text-[6.5rem] leading-[0.9] text-muted overflow-visible wrap-break-word tracking-tight drop-shadow-sm py-4 sm:py-0"
        >
          {cookie.data.name}
        </h1>

        <p
          class="mt-6 md:mt-8 text-lg sm:text-xl md:text-2xl text-gray-500 font-light leading-snug max-w-lg"
        >
          {cookie.data.description}
        </p>

        <div class="mt-8 md:mt-12 flex flex-col gap-4 w-full sm:w-fit">
          <a
            href="/arma-tu-caja"
            class="w-fit bg-muted text-white px-8 md:px-10 py-3 md:py-4 rounded-full font-black text-lg hover:bg-black transition-all border-[3px] md:border-4 border-muted cursor-pointer shadow-md text-center inline-block"
          >
            Ordenar por WhatsApp
          </a>
          <a
            href="/arma-tu-caja"
            class="w-fit bg-white text-muted px-8 md:px-10 py-3 md:py-4 rounded-full font-black text-lg hover:bg-gray-50 transition-all border-2 border-muted cursor-pointer shadow-md text-center inline-block"
          >
            Agregar a la caja
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
