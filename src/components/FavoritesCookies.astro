---
import { getCollection } from "astro:content";
import CookieCard from "./CookieCard.astro";

const cookies = await getCollection("cookies");
---

<section
  class="max-w-7xl flex flex-col gap-6 mx-auto bg-white px-6 py-15 md:px-10 lg:px-14"
>
  <h2 class="text-primary sm:text-muted text-4xl md:text-6xl mb-6 climate">
    Las favoritas
  </h2>

  <ul
    class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-6 list-none p-0"
  >
    {
      cookies.slice(0, 3).map((cookie) => (
        <li>
          <CookieCard cookie={cookie} />
        </li>
      ))
    }
  </ul>

  <button
    class="w-full py-4 rounded-full bg-muted text-white text-xl font-bold tracking-wide transition-colors duration-200 cursor-pointer hover:bg-primary hover:text-black"
  >
    Ordena ahora
  </button>
</section>
