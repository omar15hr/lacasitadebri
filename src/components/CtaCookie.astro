---
import { Image } from "astro:assets";
---

<section
  class="max-w-300 mx-auto px-6 py-10 md:px-10 lg:px-14 flex justify-center mt-6 sm:mt-12 mb-12"
>
  <div
    class="relative w-full max-w-5xl bg-[#FFEA55] rounded-[3rem] p-8 md:p-14 lg:p-16 flex flex-col md:flex-row items-center justify-between isolation-auto"
  >
    <div
      class="flex-1 flex flex-col justify-center items-start z-20 w-full mb-12 md:mb-0 relative order-2 md:order-1 mt-6 md:mt-0"
    >
      <h2
        class="flex flex-col gap-1 w-full max-w-xl mb-6 leading-[1.1] md:leading-[1.15]"
      >
        <span
          class="climate text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] text-white whitespace-normal sm:whitespace-nowrap"
          style="-webkit-text-stroke: 2px #111;"
        >
          ARMA TU CAJA
        </span>
        <span
          class="text-3xl sm:text-4xl md:text-5xl lg:text-[3.5rem] font-black text-white whitespace-normal sm:whitespace-nowrap"
          style="-webkit-text-stroke: 1.5px #111;"
        >
          como a ti te gusta
        </span>
      </h2>
      <a
        href="/arma-tu-caja"
        class="bg-[#111] text-white px-8 py-3.5 rounded-full font-bold text-lg md:text-xl hover:bg-black transition-colors inline-block text-center cursor-pointer mt-2 tracking-wide"
      >
        Armar mi caja
      </a>
    </div>

    <div
      class="relative flex-1 flex justify-center md:justify-end items-center z-10 w-full max-w-75 md:max-w-125 order-1 md:order-2 pointer-events-none mt-8 md:mt-0 overflow-visible"
    >
      <Image
        src="/cta-cookie.png"
        alt="Cookie"
        width={900}
        height={900}
        class="relative z-10 w-75 md:w-170 h-auto object-contain transform md:translate-x-12 lg:translate-x-20 md:scale-[1.3] drop-shadow-2xl select-none"
      />
    </div>
  </div>
</section>
