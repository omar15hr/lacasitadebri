---
import { Image } from "astro:assets";

interface Cookie {
  name: string;
  price: string;
  src: string;
  alt: string;
  bg: string;
}

const cookies: Cookie[] = [
  {
    name: "Nombre cookie",
    price: "$0.00",
    src: "/cookie.png",
    alt: "Cookie de chocolate chip",
    bg: "#F5F0E8",
  },
  {
    name: "Nombre cookie",
    price: "$0.00",
    src: "/cookie.png",
    alt: "Cookie de nuez y chocolate",
    bg: "#FAF6F0",
  },
  {
    name: "Nombre cookie",
    price: "$0.00",
    src: "/cookie.png",
    alt: "Cookie dark con marshmallow",
    bg: "#F2EDE6",
  },
  {
    name: "Nombre cookie",
    price: "$0.00",
    src: "/cookie.png",
    alt: "Cookie de chocolate chip",
    bg: "#F5F0E8",
  },
  {
    name: "Nombre cookie",
    price: "$0.00",
    src: "/cookie.png",
    alt: "Cookie de nuez y chocolate",
    bg: "#FAF6F0",
  },
  {
    name: "Nombre cookie",
    price: "$0.00",
    src: "/cookie.png",
    alt: "Cookie dark con marshmallow",
    bg: "#F2EDE6",
  },
];
---

<section
  class="max-w-7xl flex flex-col gap-6 mx-auto bg-white px-6 py-15 md:px-10 lg:px-14"
>
  <h2 class="text-muted text-6xl mb-6 climate">Nuestros sabores</h2>

  <ul
    class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-6 list-none p-0"
  >
    {
      cookies.map((cookie) => (
        <li>
          <div class="flex flex-col gap-3">
            <div class="relative w-full aspect-square rounded-3xl overflow-hidden bg-gray-secondary">
              <Image
                src={cookie.src}
                alt={cookie.alt}
                width={300}
                height={288}
                class="absolute inset-0 w-full h-full object-contain p-4 drop-shadow-lg"
                loading="lazy"
                decoding="async"
              />
            </div>

            <div class="flex flex-col gap-0.5 px-1">
              <span class="text-lg font-extrabold text-muted leading-snug">
                {cookie.name}
              </span>
              <span class="text-base text-gray-primary leading-snug">
                {cookie.price}
              </span>
            </div>
          </div>
        </li>
      ))
    }
  </ul>

  <button
    class="w-full py-4 rounded-full bg-muted text-white text-xl font-bold tracking-wide transition-colors duration-200 cursor-pointer"
  >
    Ordena ahora
  </button>
</section>
